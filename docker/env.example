# Elettra Environment Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL for production nginx proxy
# Used at runtime by the nginx container to proxy /auth and /api requests
API_BACKEND_URL=http://isaac-elettra.dacd.supsi.ch:8002

# Backend API URL for client-side requests (build-time)
# Leave empty when using nginx proxy, or set to full URL for direct API access
VITE_API_ROOT=

# =============================================================================
# Development Configuration
# =============================================================================

# Vite dev proxy target when running in Docker
# (required so the container can reach the host backend)
VITE_API_PROXY_TARGET=http://host.docker.internal:8002

# npm registry and proxy settings used during Docker image builds.
# Keep the default registry unless your server requires an internal mirror.
NPM_REGISTRY=https://registry.npmjs.org/
# HTTP_PROXY=http://proxy.example:3128
# HTTPS_PROXY=http://proxy.example:3128
# NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Pre-filled authentication token for development/testing (optional)
# VITE_TEST_PASSWORD=your-development-token
